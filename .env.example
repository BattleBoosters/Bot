# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# --- Optional API keys ---
# COINGECKO_API_KEY=                # CG Pro for top 5000 listed (paid)
# CMC_API_KEY=                      # Optional CMC cross-check
# BIRDEYE_API_KEY=                  # Solana premium OHLCV (paid)
# HELIUS_API_KEY=                   # Solana RPC for on-chain accumulation (free 100k req/mo)
# ANTHROPIC_API_KEY=                # For optional Sonnet 4.6 LLM filter

# --- Universe filters (defaults shown) ---
# SCANNER_MCAP_MIN_USD=1000000      # Lower mcap bound
# SCANNER_MCAP_MAX_USD=300000000    # Upper mcap bound. Push to 500M for "second leg" plays.
# SCANNER_MIN_AGE_DAYS=14
# SCANNER_MIN_VOL_MCAP_RATIO=0.05
# SCANNER_MIN_VOL_24H_USD=100000
# SCANNER_NETWORKS=solana,eth,base,arbitrum,bsc

# --- Trend scoring (lagging signal) ---
# SCANNER_SCORE_THRESHOLD=0.55
# SCANNER_WATCHLIST_THRESHOLD=0.40
# SCANNER_HIGHLIGHT_TOP_N=10
# SCANNER_CHART_TOP_N=5
# SCANNER_OHLCV_DAYS=365
# SCANNER_REALERT_COOLDOWN_DAYS=5
# SCANNER_REJECT_WASH_TRADE=true

# --- Accumulation scoring (leading signal, on-chain) ---
# SCANNER_ACCUMULATION_ENABLED=true
# SCANNER_ACCUMULATION_THRESHOLD=0.50
# SCANNER_ONCHAIN_CONCURRENCY=4
# SCANNER_ONCHAIN_MAX_TOKENS=200    # cap snapshot job within Helius free tier

# --- Daemon scheduling ---
# SCANNER_FULL_SCAN_HOURS=1
# SCANNER_FULL_SCAN_MINUTE=30
# SCANNER_WATCHLIST_SCAN_MINUTES=240

# --- Storage ---
# SCANNER_CACHE_DIR=./data/cache
# SCANNER_DB_PATH=./data/scanner.db
# SCANNER_LLM_FILTER_ENABLED=false
